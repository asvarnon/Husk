# Copy this file to .env and fill in real values. .env is gitignored.
# All variables except SEARXNG_URL and CONTEXT_FORGE_DB are required — the bot exits at
# startup if any required one is missing.

# Discord bot token (Discord Developer Portal -> your application -> Bot).
DISCORD_TOKEN=<bot-token>

# OpenAI-compatible backend base URL. Any runner works — Ollama, llama.cpp (llama-server),
# LM Studio, etc. Husk talks to {LLM_BASE_URL}/v1/chat/completions. Give the server root
# (e.g. http://host:11434) or a .../v1 URL — both are accepted. Use http:// locally:
# distillation reuses this endpoint over a no-TLS client.
# (Legacy OLLAMA_HOST still works as an alias if LLM_BASE_URL is unset.)
LLM_BASE_URL=http://<llm-host>:11434

# Chat + distillation model id, as your runner reports it (e.g. `gemma2:latest` in Ollama).
# (Legacy OLLAMA_MODEL still works as an alias.)
LLM_MODEL=<model-name>

# Optional. Bearer token for the chat endpoint (LM Studio / hosted gateways). Local runners
# ignore it. Chat only — the distiller has no auth. Leave blank/omit for local backends.
LLM_API_KEY=

# Redis connection string — hot 24h+ conversation memory.
REDIS_URL=redis://<redis-host>:6379

# Optional. SearXNG JSON search endpoint, used by the web_search tool.
# Omit it and the bot runs fine without web search (chat + memory still work). See README.
SEARXNG_URL=http://<searxng-host>:8888/search

# The system prompt / persona — this is where you give the bot its identity.
# Multiline, double-quoted. (This is the only "branding" — the binary itself is persona-agnostic.)
PERSONA="You are a concise, helpful assistant in a Discord server."

# Optional. Path to the long-term memory SQLite file. Defaults to ~/.context-forge/discord.db.
# Point this at a mounted volume so memory survives restarts (see README).
CONTEXT_FORGE_DB=/data/discord.db
