# Homelab Configuration Template

# Proxmox Endpoint
[[endpoints]]
name = "proxmox"
url = "https://<proxmox-ip>:8006"
[endpoints.auth]
type = "api-token"
id_env = "PROXMOX_TOKEN_ID"
secret_env = "PROXMOX_TOKEN_SECRET"

# OPNsense Endpoint
[[endpoints]]
name = "opnsense"
url = "https://<opnsense-ip>"
[endpoints.auth]
type = "basic"
user_env = "OPNSENSE_API_KEY"
pass_env = "OPNSENSE_API_SECRET"

# LLM Endpoint (llama.cpp)
[[endpoints]]
name = "llama"
url = "http://<llama-ip>:8080"
[endpoints.auth]
type = "none"

# LLM Endpoint (Ollama)
[[endpoints]]
name = "ollama"
url = "http://<ollama-ip>:11434"
[endpoints.auth]
type = "none"
